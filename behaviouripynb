      "source": [
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "# Assuming crm_df is already defined from cell 7116b0b7\n",
        "crm_plot_df = crm_df.copy()\n",
        "\n",
        "def clean_and_convert(value):\n",
        "    if isinstance(value, str):\n",
        "        # Improved cleaning: handle various formats\n",
        "        value = value.replace(' days', '').replace('%', '').replace(' hours', '') \\\n",
        "                     .replace('< ', '').replace('+', '').replace('-', '')\n",
        "        if value in ['N/A', 'Baseline', '']:\n",
        "            return np.nan\n",
        "        try:\n",
        "            return float(value)\n",
        "        except ValueError:\n",
        "            return np.nan\n",
        "    return value\n",
        "\n",
        "# Apply cleaning\n",
        "cols_to_clean = ['Traditional CRM', 'Rule-Based CRM', 'Proposed Multi-Agent CRM']\n",
        "for col in cols_to_clean:\n",
        "    crm_plot_df[col] = crm_plot_df[col].apply(clean_and_convert)\n",
        "\n",
        "# Melt for seaborn\n",
        "crm_plot_df_melted = crm_plot_df.melt(id_vars='Metric', var_name='CRM System', value_name='Value')\n",
        "\n",
        "# Define custom dashes for grayscale distinction\n",
        "line_dashes = [(1, 0), (2, 2), (5, 1)] # Solid, dashed, dash-dot\n",
        "\n",
        "plt.figure(figsize=(16, 8))\n",
        "sns.lineplot(x='Metric', y='Value', hue='CRM System', data=crm_plot_df_melted, marker='o', palette='Greys', style='CRM System', dashes=line_dashes)\n",
        "\n",
        "plt.ylabel('Normalized Performance Units')\n",
        "plt.xlabel('Evaluation Metric')\n",
        "plt.xticks(rotation=45, ha='right')\n",
        "plt.legend(title='CRM System', loc='upper left')\n",
        "plt.grid(axis='y', linestyle='--', alpha=0.6)\n",
        "plt.tight_layout()\n",
        "plt.show()"
