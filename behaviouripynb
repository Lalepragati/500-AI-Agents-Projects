        "workeloo_vals += workeloo_vals[:1]\n",
        "commercial_vals += commercial_vals[:1]\n",
        "angles += angles[:1]\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(8, 8), subplot_kw=dict(polar=True)) # Increased figure size\n",
        "ax.plot(angles, workeloo_vals, label='hyperautomation framework', color='black') # Set line color to black\n",
        "ax.fill(angles, workeloo_vals, alpha=0.25, facecolor='darkgray') # Set fill color to dark gray\n",
        "ax.plot(angles, commercial_vals, label='Commercial Systems', color='dimgray') # Set line color to dimgray\n",
        "ax.fill(angles, commercial_vals, alpha=0.25, facecolor='lightgray') # Set fill color to light gray\n",
        "ax.set_xticks(angles[:-1])\n",
        "ax.set_xticklabels(labels, va='center', ha='center') # Added vertical and horizontal alignment\n",
