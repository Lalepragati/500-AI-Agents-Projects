        "import pandas as pd\n",
        "import numpy as np\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.preprocessing import LabelEncoder, StandardScaler\n",
        "from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score, confusion_matrix\n",
        "from sklearn.ensemble import RandomForestClassifier\n",
        "import xgboost as xgb\n",
        "\n",
        "# -----------------------------\n",
        "# 1. Generate Synthetic Dataset\n",
        "# -----------------------------\n",
        "np.random.seed(42)\n",
        "n_samples = 500\n",
        "\n",
        "data = pd.DataFrame({\n",
        "    \"Lead_ID\": range(1, n_samples+1),\n",
        "    \"Age\": np.random.randint(22, 60, n_samples),\n",
        "    \"Gender\": np.random.choice([\"Male\", \"Female\"], n_samples),\n",
        "    \"Location\": np.random.choice([\"USA\", \"India\", \"UK\", \"Germany\"], n_samples),\n",
        "    \"Company_Size\": np.random.choice([\"Small\", \"Medium\", \"Large\"], n_samples),\n",
        "    \"Industry\": np.random.choice([\"Technology\", \"Healthcare\", \"Finance\", \"Education\"], n_samples),\n",
        "    \"Job_Title\": np.random.choice([\"Manager\", \"Director\", \"CEO\", \"Engineer\"], n_samples),\n",
        "    \"Website_Visits\": np.random.randint(1, 50, n_samples),\n",
        "    \"Pages_Viewed\": np.random.randint(1, 20, n_samples),\n",
        "    \"Time_On_Site\": np.random.uniform(1, 300, n_samples),\n",
        "    \"Email_Opens\": np.random.randint(0, 15, n_samples),\n",
        "    \"Email_Clicks\": np.random.randint(0, 10, n_samples),\n",
        "    \"Form_Submissions\": np.random.randint(0, 5, n_samples),\n",
        "    \"Content_Downloads\": np.random.randint(0, 5, n_samples),\n",
        "    \"Event_Attendance\": np.random.choice([0, 1], n_samples),\n",
        "    \"Last_Activity_Days\": np.random.randint(0, 60, n_samples),\n",
        "    \"Lead_Source\": np.random.choice([\"Organic Search\", \"Paid Ad\", \"Referral\", \"Social Media\"], n_samples),\n",
        "    \"Engagement_Score\": np.random.uniform(0, 100, n_samples),\n",
        "    \"Converted\": np.random.choice([0, 1], n_samples, p=[0.7, 0.3])  # 30% conversion rate\n",
        "})\n",
        "\n",
        "# -----------------------------\n",
        "# 2. Data Cleaning & Encoding\n",
        "# -----------------------------\n",
        "# Encode categorical variables\n",
        "categorical_cols = [\"Gender\", \"Location\", \"Company_Size\", \"Industry\", \"Job_Title\", \"Lead_Source\"]\n",
        "encoder = LabelEncoder()\n",
        "\n",
        "for col in categorical_cols:\n",
        "    data[col] = encoder.fit_transform(data[col])\n",
        "\n",
        "# Features and target\n",
        "X = data.drop([\"Lead_ID\", \"Converted\"], axis=1)\n",
        "y = data[\"Converted\"]\n",
        "\n",
        "# Scale numerical features\n",
        "scaler = StandardScaler()\n",
        "X_scaled = scaler.fit_transform(X)\n",
        "\n",
        "# -----------------------------\n",
        "# 3. Train-Test Split\n",
        "# -----------------------------\n",
        "X_train, X_test, y_train, y_test = train_test_split(X_scaled, y, test_size=0.3, random_state=42)\n",
        "\n",
        "# -----------------------------\n",
        "# 4. Random Forest Model\n",
        "# -----------------------------\n",
        "rf_model = RandomForestClassifier(n_estimators=100, random_state=42)\n",
        "rf_model.fit(X_train, y_train)\n",
        "rf_preds = rf_model.predict(X_test)\n",
        "\n",
        "# -----------------------------\n",
        "# 5. XGBoost Model\n",
        "# -----------------------------\n",
        "xgb_model = xgb.XGBClassifier(use_label_encoder=False, eval_metric=\"logloss\", random_state=42)\n",
        "xgb_model.fit(X_train, y_train)\n",
        "xgb_preds = xgb_model.predict(X_test)\n",
        "\n",
        "# -----------------------------\n",
        "# 6. Evaluation Function\n",
        "# -----------------------------\n",
        "def evaluate_model(name, y_true, y_pred):\n",
        "    print(f\"\\n{name} Performance:\")\n",
        "    print(\"Accuracy:\", accuracy_score(y_true, y_pred))\n",
        "    print(\"Precision:\", precision_score(y_true, y_pred))\n",
        "    print(\"Recall:\", recall_score(y_true, y_pred))\n",
        "    print(\"F1 Score:\", f1_score(y_true, y_pred))\n",
        "    print(\"Confusion Matrix:\\n\", confusion_matrix(y_true, y_pred))\n",
        "\n",
        "# Evaluate both models\n",
        "evaluate_model(\"Random Forest\", y_test, rf_preds)\n",
        "evaluate_model(\"XGBoost\", y_test, xgb_preds)\n"
      ]
    },
