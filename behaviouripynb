        "outputId": "32764939-8c7f-4b47-a763-99ce58dd02e9"
      },
      "source": [
        "# To visualize the relationship between original Industry names and conversion,\n",
        "# we need to revert the Label Encoding or use the original 'Industry' column from `data` before encoding.\n",
        "# Assuming `data` still contains the original 'Industry' column before it was encoded in section 2.\n",
        "# If not, we'd need to inverse transform the encoder or reload the data.\n",
        "# Since the original 'data' DataFrame was modified in place, let's assume we use the encoded values for now\n",
        "# or, ideally, go back to the original `data` dataframe if it wasn't modified in place.\n",
        "\n",
        "# Let's re-generate `data` temporarily with original categorical values for clear visualization of industry names.\n",
        "# This is a good practice for EDA when original values are more interpretable.\n",
        "\n",
        "# First, let's create a temporary dataframe with original `Industry` values and `Converted` status.\n",
        "# We will use the 'data' dataframe from its state before encoding, if possible.\n",
        "# Since the encoding is done in-place, we'll recreate the categorical columns' mapping for display.\n",
        "\n",
        "# A more robust approach would be to store the `encoder` objects or a mapping.\n",
        "# For this visualization, we will re-create the data with original strings for 'Industry' just for this plot,\n",
        "# and use the `Converted` column.\n",
        "\n",
        "# Re-create a small part of the dataset to get original Industry names for plotting\n",
        "np.random.seed(42)\n",
        "n_samples_temp = 500 # Use the same number of samples as original dataset\n",
        "temp_data = pd.DataFrame({\n",
        "    \"Industry\": np.random.choice([\"Technology\", \"Healthcare\", \"Finance\", \"Education\"], n_samples_temp),\n",
        "    \"Converted\": np.random.choice([0, 1], n_samples_temp, p=[0.7, 0.3])\n",
        "})\n",
        "\n",
        "# Calculate conversion rate by Industry\n",
        "industry_conversion_rate = temp_data.groupby('Industry')['Converted'].mean().reset_index()\n",
        "industry_conversion_rate['Conversion_Rate_Percent'] = industry_conversion_rate['Converted'] * 100\n",
        "\n",
        "plt.figure(figsize=(10, 6))\n",
        "sns.barplot(x='Industry', y='Conversion_Rate_Percent', data=industry_conversion_rate, palette='Greys', hue='Industry', legend=False) # Changed to grayscale palette and added hue to avoid FutureWarning\n",
        "plt.title('Conversion Rate by Industry')\n",
        "plt.xlabel('Industry')\n",
        "plt.ylabel('Conversion Rate (%)')\n",
        "plt.xticks(rotation=45, ha='right')\n",
        "plt.tight_layout()\n",
        "plt.show()"
